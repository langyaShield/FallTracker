{
  "id": "liepin",
  "name": "猎聘",
  "enabled": true,
  "description": "猎聘职位搜索 - 猎聘反爬虫中等，建议设置延迟并配置代理。需要从浏览器复制 cookie。",
  "request": {
    "url": "https://www.liepin.com/zhaopin/?city=010&dq=010&key=前端开发&curPage=0",
    "method": "GET",
    "headers": {
      "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
      "Referer": "https://www.liepin.com/",
      "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
      "Accept-Language": "zh-CN,zh;q=0.9,en;q=0.8"
    },
    "encoding": "utf-8",
    "proxy": "",
    "delay_range": [2.0, 4.0]
  },
  "parse": {
    "type": "css",
    "item_selector": ".job-list-item",
    "fields": [
      {
        "name": "company",
        "selector": ".company-name",
        "attr": "text"
      },
      {
        "name": "position",
        "selector": ".job-title",
        "attr": "text"
      },
      {
        "name": "link",
        "selector": "a.job-title",
        "attr": "href"
      },
      {
        "name": "tags",
        "selector": ".job-tags span",
        "attr": "text",
        "multiple": true
      }
    ]
  }
}
